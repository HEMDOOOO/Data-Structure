#include <iostream>
#include <stack>
#include <string>
#include <cmath>
using namespace std;
int applyOp(int first, int second, char op)
{
    if (op == '+') return first + second;
    if (op == '-') return first - second;
    if (op == '*') return first * second;
    if (op == '/') return first / second;
    if (op == '^') return pow(first, second);
    return 0;
}
int evaluatePostfix(string exp)
{
    stack<int> stk;
    for (int i = 0; i < exp.length(); i++)
    {
        char c = exp[i];
        if (isdigit(c))
        {
            stk.push(c - '0');
        }
        else
        {
            int second = stk.top();
            stk.pop();
            int first = stk.top();
            stk.pop();
            int result = applyOp(first, second, c);
            stk.push(result);
        }
    }
    return stk.top();
}
int main()
{
    string postfix = "32+72/73+2**+";
    cout << evaluatePostfix(postfix);
    return 0;
}
