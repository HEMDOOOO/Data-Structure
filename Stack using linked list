#include <iostream>
using namespace std;
struct Node
{
    int data;
    Node* next;
    Node* prev;
};
class Stack
{
private:
    Node* head;
    Node* tail;
public:
    Stack()
    {
        head = NULL;
        tail = NULL;
    }
    bool isEmpty()
    {
        return head == NULL;
    }
    // push
    void push(int val)
    {
        Node* newNode = new Node;
        newNode->data = val;
        newNode->next = NULL;
        newNode->prev = NULL;
        if (isEmpty())
        {
            head = tail = newNode;
        }
        else
        {
            tail->next = newNode;
            newNode->prev = tail;
            tail = newNode;
        }
    }
    // pop
    void pop()
    {
        if (isEmpty())
        {
            cout << "Stack Underflow\n";
            return;
        }
        if (head == tail)
        {
            delete head;
            head = tail = NULL;
            return;
        }
        Node* curr = tail;  
        tail = tail->prev;
        tail->next = NULL;
        delete curr;
    }
    // peek
    int peek()
    {
        if (isEmpty())
        {
            cout << "Empty\n";
            return -1;
        }

        return tail->data;
    }
    // display
    void display()
    {
        if (isEmpty())
        {
            cout << "Empty\n";
            return;
        }
        Node* curr = tail; 
        while (curr != NULL)
        {
            cout << curr->data << " ";
            curr = curr->prev;
        }
        cout << endl;
    }
    // destructor
    ~Stack()
    {
        while (!isEmpty())
        {
            pop();
        }
    }
};
int main()
{
    Stack s;
    s.push(10);
    s.push(20);
    s.push(30);
    s.push(40);
    s.display();
    s.pop();
    s.display();
    cout << s.peek();
}
