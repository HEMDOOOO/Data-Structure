#include <iostream>
#include <stack>
#include <string>
using namespace std;
int Priority(char c)
{
    if (c == '+' || c == '-')
        return 1;
    else if (c == '*' || c == '/')
        return 2;
    else if (c == '^')
        return 3;
    else
        return 0;
}
string infix_to_postfix(string exp)
{
    stack<char> stk;
    string output = "";
    for (int i = 0; i < exp.length(); i++)
    {
        char c = exp[i];
        if (c == ' ')
            continue;
        if (isdigit(c) || isalpha(c))
        {
            output += c;
        }
        else if (c == '(')
        {
            stk.push(c);
        }
        else if (c == ')')
        {
            while (!stk.empty() && stk.top() != '(')
            {
                output += stk.top();
                stk.pop();
            }
            if (!stk.empty())
                stk.pop();
        }
        else
        {
            while (!stk.empty() &&Priority(c) <= Priority(stk.top()))
            {
                output += stk.top();
                stk.pop();
            }
            stk.push(c);
        }
    }
    while (!stk.empty())
    {
        output += stk.top();
        stk.pop();
    }
    return output;
}
int main()
{
    string infixExpression = "(3+2)+7/2*((7+3)*2)";
    cout << infix_to_postfix(infixExpression) << endl;
    return 0;
}
