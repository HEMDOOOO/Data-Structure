#include <iostream>
#include <stack>
using namespace std;
bool isBalanced(string s)
{
    stack<char> st;
    for (int i = 0; i < s.length(); i++)
    {
        char c = s[i];
        // opening
        if (c == '(' || c == '{' || c == '[')
        {
            st.push(c);
        }
        // closing
        else if (c == ')' || c == '}' || c == ']')
        {
            if (st.empty())
                return false;
            char top = st.top();
            st.pop();
            if (c == ')' && top != '(') return false;
            if (c == '}' && top != '{') return false;
            if (c == ']' && top != '[') return false;
        }
    }
    return st.empty();
}
int main()
{
    string s;
    cout << "Enter : ";
    cin >> s;
    if (isBalanced(s))
        cout << "Balanced";
    else
        cout << "Not Balanced";
}
